package server

import (
	"bufio"
	"os"
	"path/filepath"
	"strconv"
	"strings"
	"sync"
)

// Agent is a loaded agent definition. Prompt is the markdown body (the agent's
// system prompt); empty Prompt means "use the default system prompt". Tools is
// an allow/deny map (tool name -> allowed); nil means all tools allowed.
type Agent struct {
	Name        string
	Description string
	Mode        string
	Model       string
	Temperature *float64
	Prompt      string
	Tools       map[string]bool
}

// toolAllowed reports whether the named tool may be used by this agent. With no
// Tools policy (nil/empty), everything is allowed; otherwise a tool is allowed
// unless explicitly mapped to false.
func (a Agent) toolAllowed(name string) bool {
	if len(a.Tools) == 0 {
		return true
	}
	allowed, ok := a.Tools[name]
	if !ok {
		return true
	}
	return allowed
}

var (
	agentCacheMu sync.Mutex
	agentCache   = map[string]map[string]Agent{} // workdir -> name -> Agent
)

// agentDirs returns the agent definition directories in precedence order
// (global first, then project so project overrides global).
func agentDirs(workdir string) []string {
	var dirs []string
	if home, err := os.UserHomeDir(); err == nil {
		dirs = append(dirs, filepath.Join(home, ".config", "opencode", "agent"))
	}
	if workdir != "" {
		dirs = append(dirs, filepath.Join(workdir, ".opencode", "agent"))
	}
	return dirs
}

// loadAgents scans the agent dirs for *.md definitions and returns them keyed by
// agent name (lowercased). Result is cached per workdir. Malformed files are
// skipped. Returns an empty map when no agents exist.
func loadAgents(workdir string) map[string]Agent {
	agentCacheMu.Lock()
	defer agentCacheMu.Unlock()
	if cached, ok := agentCache[workdir]; ok {
		return cached
	}
	agents := map[string]Agent{}
	for _, dir := range agentDirs(workdir) {
		entries, err := os.ReadDir(dir)
		if err != nil {
			continue
		}
		for _, e := range entries {
			if e.IsDir() || !strings.HasSuffix(e.Name(), ".md") {
				continue
			}
			a, ok := parseAgentFile(filepath.Join(dir, e.Name()))
			if !ok {
				continue
			}
			if a.Name == "" {
				a.Name = strings.TrimSuffix(e.Name(), ".md")
			}
			agents[strings.ToLower(a.Name)] = a
		}
	}
	agentCache[workdir] = agents
	return agents
}

// resolveAgent returns the agent for the given name (case-insensitive). When the
// name is empty or unknown, it returns a zero Agent (ok=false) so callers fall
// back to default behavior.
func resolveAgent(workdir, name string) (Agent, bool) {
	name = strings.ToLower(strings.TrimSpace(name))
	if name == "" {
		return Agent{}, false
	}
	a, ok := loadAgents(workdir)[name]
	return a, ok
}

// parseAgentFile reads scalar frontmatter (name/description/mode/model/
// temperature) and captures the post-frontmatter markdown body as Prompt.
func parseAgentFile(path string) (Agent, bool) {
	f, err := os.Open(path)
	if err != nil {
		return Agent{}, false
	}
	defer f.Close()
	sc := bufio.NewScanner(f)
	sc.Buffer(make([]byte, 0, 64*1024), 1024*1024)

	var a Agent
	inFront := false
	frontDone := false
	lineNo := 0
	var body strings.Builder
	for sc.Scan() {
		line := sc.Text()
		lineNo++
		trimmed := strings.TrimSpace(line)
		if lineNo == 1 && trimmed == "---" {
			inFront = true
			continue
		}
		if inFront && !frontDone {
			if trimmed == "---" {
				frontDone = true
				continue
			}
			parseAgentFrontLine(&a, line)
			continue
		}
		// Body (everything after frontmatter, or whole file if no frontmatter).
		body.WriteString(line)
		body.WriteString("\n")
	}
	a.Prompt = strings.TrimSpace(body.String())
	// A file with neither a name nor a body is not a usable agent.
	if a.Name == "" && a.Prompt == "" && a.Description == "" {
		return Agent{}, false
	}
	return a, true
}

// parseAgentFrontLine parses a single scalar "key: value" frontmatter line.
// Nested/map keys (e.g. tools:) are ignored in this chunk.
func parseAgentFrontLine(a *Agent, line string) {
	idx := strings.Index(line, ":")
	if idx < 0 {
		return
	}
	key := strings.TrimSpace(line[:idx])
	val := strings.TrimSpace(line[idx+1:])
	// Strip surrounding quotes.
	val = strings.Trim(val, `"'`)
	switch strings.ToLower(key) {
	case "name":
		a.Name = val
	case "description":
		a.Description = val
	case "mode":
		a.Mode = val
	case "model":
		a.Model = val
	case "temperature":
		if val != "" {
			if t, err := strconv.ParseFloat(val, 64); err == nil {
				a.Temperature = &t
			}
		}
	}
}

func agentMode(a Agent) string {
	if strings.TrimSpace(a.Mode) != "" {
		return a.Mode
	}
	return "build"
}
